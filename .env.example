HERMES_CODEXBAR_API_KEY=replace-with-a-long-random-token
HERMES_STATE_DB=$HOME/.hermes/state.db
HERMES_CODEXBAR_TIMEZONE=Europe/Berlin
HERMES_CODEXBAR_LOOKBACK_DAYS=30
HERMES_CODEXBAR_MODEL_PRICING_JSON='{"gpt-5.5":{"input_uncached":1.25,"input_cached":0.125,"output":10}}'

# AetherAPI model prices are fetched and cached for aether/custom providers.
# Set empty/false/off to disable remote Aether pricing.
HERMES_CODEXBAR_AETHER_MODELS_URL=https://api.aetherapi.dev/v1/models
HERMES_CODEXBAR_AETHER_PRICING_TTL_SECONDS=3600

# Optional local-development fallback. Do not use this for CodexBar.
# HERMES_CODEXBAR_ALLOW_DEV_DEFAULT=true
